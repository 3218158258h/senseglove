<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Macro: add state interfaces -->
  <xacro:macro name="add_state_interfaces" params="joint_name">
    <joint name="${joint_name}">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </xacro:macro>

  <!-- Macro: add command interfaces -->
  <xacro:macro name="add_command_interfaces" params="joint_name">
    <joint name="${joint_name}">
      <command_interface name="effort"/>
    </joint>
  </xacro:macro>

  <!-- Macro: add state and command interfaces -->
  <xacro:macro name="add_state_and_command_interfaces" params="joint_name">
    <joint name="${joint_name}">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <command_interface name="effort"/>
    </joint>
  </xacro:macro>

</robot>
